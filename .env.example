# ============================================
# DevStep — Environment Variables Template
# ============================================
# 이 파일을 복사하여 .env로 사용하세요:
#   cp .env.example .env

# ── PostgreSQL (로컬 Docker) ──
POSTGRES_USER=devstep
POSTGRES_PASSWORD=devstep_local_2026
POSTGRES_DB=devstep_db
DATABASE_URL=postgresql://devstep:devstep_local_2026@db:5432/devstep_db

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Next.js (Frontend) ──
NEXT_PUBLIC_API_URL=http://localhost:8000
# Supabase Cloud 전환 시 아래 값을 채우세요
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── OpenAI / AI Engine ──
OPENAI_API_KEY=sk-your-key-here

# ── FastAPI (Backend) ──
CORS_ORIGINS=http://localhost:3000
