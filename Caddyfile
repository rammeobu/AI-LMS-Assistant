# devstep.duckdns.org — Automatic HTTPS Gateway
# Caddy handles SSL certificates automatically via Let's Encrypt.

devstep.duckdns.org {
    # Reverse proxy to the Next.js frontend
    reverse_proxy devstep-web:3000

    # Explicitly proxy /api/v1 to the FastAPI backend
    handle_path /api/v1/* {
        reverse_proxy devstep-ai:8000
    }

    # Enable compression
    encode gzip zstd

    # Logging (Optional, good for debugging SSL issues)
    log {
        output file /data/access.log
    }
}
