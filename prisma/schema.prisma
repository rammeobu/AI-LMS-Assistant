generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String?
  image       String?
  school      String?
  major       String?
  grade       Int?
  targetJob   String?
  targetField String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio      Portfolio?
  analysisResults AnalysisResult[]
  calendarEvents CalendarEvent[]
  teamPosts      TeamPost[]
  accounts       Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Portfolio {
  id             String  @id @default(cuid())
  userId         String  @unique
  skills         String? // JSON string
  certifications String? // JSON string
  projects       String? // JSON string
  activities     String? // JSON string
  awards         String? // JSON string
  intro          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalysisResult {
  id              String   @id @default(cuid())
  userId          String
  overallScore    Int
  scores          String   // JSON string - individual scores
  strengths       String   // JSON string
  weaknesses      String   // JSON string
  missingSkills   String   // JSON string
  recommendations String   // JSON string
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id             String  @id @default(cuid())
  title          String
  category       String
  status         String
  recruitPeriod  String?
  description    String
  requiredSkills String? // JSON string
  deadline       String?
  organizer      String?
  prize          String?
  field          String?
}

model CalendarEvent {
  id     String  @id @default(cuid())
  userId String
  title  String
  date   String
  type   String  // study, deadline, exam, personal
  ai     Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeamPost {
  id             String   @id @default(cuid())
  authorId       String
  title          String
  description    String
  skills         String   // JSON string
  currentMembers Int      @default(1)
  maxMembers     Int
  status         String   @default("모집중")
  createdAt      DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}
